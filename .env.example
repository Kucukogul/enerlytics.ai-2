SOLAR_DATA_PROVIDER=nasa
NASA_POWER_BASE_URL=https://power.larc.nasa.gov/api/temporal/climatology/point
NASA_POWER_MONTHLY_BASE_URL=https://power.larc.nasa.gov/api/temporal/monthly/point
NASA_POWER_PARAMETER=ALLSKY_SFC_SW_DWN
NASA_POWER_COMMUNITY=RE
NASA_POWER_FORMAT=JSON
REQUEST_TIMEOUT_SECONDS=15
ENABLE_NASA_CACHE=true
NASA_CACHE_DIR=data/raw/nasa_power
NASA_CACHE_TTL_HOURS=720
PVGIS_BASE_URL=https://re.jrc.ec.europa.eu/api/v5_2/MRcalc
PVGIS_START_YEAR=2015
PVGIS_END_YEAR=2020
ENABLE_PVGIS_CACHE=true
PVGIS_CACHE_DIR=data/raw/pvgis
PVGIS_CACHE_TTL_HOURS=720

PANEL_EFFICIENCY=0.20
SYSTEM_LOSSES=0.14
DEFAULT_SYSTEM_AREA_M2=25
PROJECT_LIFETIME_YEARS=25

CAPEX_USD=12000
OPEX_ANNUAL_USD=180
USD_TRY=32.0
DISCOUNT_RATE_TR=0.30
LAND_COST_TRY=0
ELECTRICITY_SALE_PRICE_TRY_KWH=2.5
